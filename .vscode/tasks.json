			"command": "${workspaceFolder}/scripts/run_repo_python.sh",
			"windows": {
				"command": "${workspaceFolder}\\.venv\\Scripts\\python.exe"
			},
			"args": [
				"scripts/refresh_repo_health_dashboard.py"
			],
			"problemMatcher": []
		},
		{
			"label": "AI: Validate nested unused parameter tests",
			"type": "process",
			"command": "${workspaceFolder}/scripts/run_repo_python.sh",
			"windows": {
				"command": "${workspaceFolder}\\.venv\\Scripts\\python.exe"
			},
			"args": [
				"-m",
				"pytest",
				"--no-cov",
				"tests/test_analyzers_variables.py",
				"-k",
				"library_target_report_shows_typedef_for_same_lib_different_file_moduletype or unused_summary_splits_moduletype_and_singlemodule_groups",
				"-x",
				"-q",
				"--tb=short"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "test"
		},
