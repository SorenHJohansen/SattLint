				"-m",
				"pytest",
				"--no-cov",
				"tests/test_analyzers_variables.py",
				"-k",
				"library_typedef_moduleparameter_unused_fields_are_suppressed or library_target_report_shows_typedef_for_same_lib_different_file_moduletype or unused_summary_splits_moduletype_and_singlemodule_groups",
				"-x",
				"-q",
				"--tb=short"
			],
