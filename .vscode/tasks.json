{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "AI: CodeGraph Health",
			"type": "process",
			"command": "codegraph",
			"args": [
				"status",
				"${workspaceFolder}"
			],
			"problemMatcher": []
		},
		{
			"label": "AI: Sync CodeGraph Index",
			"type": "process",
			"command": "codegraph",
			"args": [
				"sync",
				"${workspaceFolder}"
			],
			"problemMatcher": []
		},
		{
			"label": "AI: Rebuild CodeGraph Index",
			"type": "process",
			"command": "codegraph",
			"args": [
