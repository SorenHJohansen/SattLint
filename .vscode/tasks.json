			"command": "${workspaceFolder}/scripts/run_repo_python.sh",
			"windows": {
				"command": "${workspaceFolder}\\.venv\\Scripts\\python.exe"
			},
			"args": [
				"-m",
				"sattlint.devtools.repo_audit",
				"--profile",
				"full",
				"--planning-context",
				"--output-dir",
				"artifacts/audit"
			],
			"problemMatcher": []
		},
		{
			"label": "AI: Bootstrap Slice",
			"type": "process",
			"command": "${workspaceFolder}/scripts/run_repo_python.sh",
			"windows": {
				"command": "${workspaceFolder}\\.venv\\Scripts\\python.exe"
			},
			"args": [
				"scripts/bootstrap_ai_slice.py"
			],
			"problemMatcher": []
		},
