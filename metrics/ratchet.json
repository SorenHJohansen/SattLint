{
  "kind": "sattlint.ai_first_ratchet",
  "schema_version": 1,
  "thresholds": {
    "agents_max_lines": 100,
    "repo_map_max_lines": 220,
    "auto_loaded_context_max_lines": 180,
    "context_optimizer_auto_loaded_line_threshold": 80,
    "preferred_file_lines": 500,
    "hard_file_lines": 800
  },
  "context_files": {
    "auto_loaded": [
      "AGENTS.md"
    ],
    "scoped_globs": [
      ".github/instructions/*.md"
    ]
  },
  "required_paths": {
    "docs": [
      "docs/maintainers/repo-map.md",
      "docs/public/architecture.md",
      "docs/maintainers/quality-gates.md"
    ],
    "vscode": [
      ".vscode/settings.json",
      ".vscode/extensions.json",
      ".vscode/tasks.json"
    ]
  },
  "context_optimizer": {
    "extension_id": "wanderleyferreiradealbuquerque.context-optimizer",
    "chat_participant": "@context-optimizer",
    "recommended_commands": [
      "/audit",
      "/compare",
      "/optimize",
      "/init"
    ]
  },
  "validation_commands": {
    "ai_edit": [
      "ruff check <touched-files>",
      "pyright <touched-files-or-owner-surface>",
      "focused pytest or owner validation"
    ],
    "pre_commit": [
      "python -m pre_commit run --all-files",
      "python scripts/context_health.py --check"
    ],
    "pre_push": [
      "sattlint-repo-audit --profile full --check-my-changes --output-dir artifacts/audit",
      "python scripts/repo_health.py --check --audit-dir artifacts/audit"
    ],
    "ci": [
      "python -m pre_commit run --all-files",
      "sattlint-repo-audit --profile full --output-dir artifacts/audit-ci --fail-on high",
      "python scripts/repo_health.py --check --audit-dir artifacts/audit-ci"
    ],
    "nightly": [
      "python scripts/context_health.py --check",
      "sattlint-repo-audit --profile full --output-dir artifacts/audit-nightly --fail-on high",
      "python scripts/repo_health.py --audit-dir artifacts/audit-nightly --history-output metrics/history/nightly-latest.json"
    ]
  }
}
