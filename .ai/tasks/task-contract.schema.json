{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SattLint AI Task Contract",
  "type": "object",
  "required": [
    "task_id",
    "title",
    "owner",
    "stage",
    "branch",
    "worktree",
    "summary",
    "files",
    "validation",
    "status"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "owner": {
      "type": "string",
      "minLength": 2
    },
    "stage": {
      "type": "string",
      "enum": [
        "executor",
        "test",
        "review"
      ]
    },
    "branch": {
      "type": "string",
      "minLength": 3
    },
    "worktree": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 10
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "blocked",
        "validated",
        "ready-for-review",
        "done"
      ]
    },
    "files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "validation": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "handoff_path": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
