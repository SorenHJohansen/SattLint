{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "*": "allow",
      "rm *": "deny"
    },
    "edit": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "task": "allow",
    "question": "allow",
    "lsp": "allow",
    "skill": "allow"
  },
  "mcp": {
    "codegraph": {
      "type": "local",
      "command": [
        "node",
        "/usr/sbin/codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": true
    }
  }
}
