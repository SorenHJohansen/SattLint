{
  "version": 1,
  "include": [
    "**/*.py",
    "**/*.js"
  ],
  "exclude": [
    "**/.git/**",
    "**/__pycache__/**",
    "**/*.pyc",
    "**/.venv/**",
    "**/venv/**",
    "**/site-packages/**",
    "**/dist-packages/**",
    "**/.pytest_cache/**",
    "**/.mypy_cache/**",
    "**/.ruff_cache/**",
    "**/.tox/**",
    "**/.nox/**",
    "**/*.egg-info/**",
    "**/.eggs/**",
    "**/node_modules/**",
    "**/build/**",
    "**/dist/**",
    "**/htmlcov/**",
    "**/coverage/**",
    "**/.idea/**",
    "**/logs/**",
    "**/tmp/**",
    "**/temp/**",
    "**/_build/**",
    "**/docs/_build/**",
    "**/site/**"
  ],
  "languages": ["python", "javascript"],
  "frameworks": [],
  "maxFileSize": 1048576,
  "extractDocstrings": true,
  "trackCallSites": true
}
